#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)"
SRC_DIR="$ROOT_DIR/.skill-staging"
CODEX_HOME="${CODEX_HOME:-$HOME/.codex}"
DEST_DIR="$CODEX_HOME/skills"

mkdir -p "$DEST_DIR"

for SKILL in beads-project-manager self-improving-agent; do
  if [ ! -d "$SRC_DIR/$SKILL" ]; then
    printf '[warn] missing staged skill: %s\n' "$SKILL" >&2
    continue
  fi

  mkdir -p "$DEST_DIR/$SKILL"
  rsync -a --delete "$SRC_DIR/$SKILL/" "$DEST_DIR/$SKILL/"
  printf '[ok] installed %s -> %s\n' "$SKILL" "$DEST_DIR/$SKILL"
done
