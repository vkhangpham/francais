#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)"
SRC_DIR="$ROOT_DIR/.skill-staging"
CODEX_HOME="${CODEX_HOME:-$HOME/.codex}"
DEST_DIR="$CODEX_HOME/skills"

if ! command -v rsync >/dev/null 2>&1; then
  printf '[error] rsync is required to install staged skills.\n' >&2
  exit 1
fi

mkdir -p "$DEST_DIR"

FOUND_SKILLS="$(find "$SRC_DIR" -mindepth 2 -maxdepth 2 -name SKILL.md -print | sort)"

if [ -z "$FOUND_SKILLS" ]; then
  printf '[error] no staged skills found under %s\n' "$SRC_DIR" >&2
  exit 1
fi

printf '%s\n' "$FOUND_SKILLS" | while IFS= read -r SKILL_FILE; do
  SKILL_DIR="$(dirname "$SKILL_FILE")"
  SKILL_NAME="$(basename "$SKILL_DIR")"
  mkdir -p "$DEST_DIR/$SKILL_NAME"
  rsync -a --delete "$SKILL_DIR/" "$DEST_DIR/$SKILL_NAME/"
  printf '[ok] installed %s -> %s\n' "$SKILL_NAME" "$DEST_DIR/$SKILL_NAME"
done
