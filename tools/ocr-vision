#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)"
SWIFT_SCRIPT="$ROOT_DIR/tools/ocr-vision.swift"

PAGE=1
DENSITY=220
INPUT=""

while [ "$#" -gt 0 ]; do
  case "$1" in
    --page)
      PAGE="$2"
      shift 2
      ;;
    --density)
      DENSITY="$2"
      shift 2
      ;;
    --help|-h)
      cat <<'EOF'
Usage:
  tools/ocr-vision <image-or-pdf>
  tools/ocr-vision --page 42 <pdf>

Notes:
  - PDF pages are 1-based.
  - PDF input is rendered to a temporary PNG before OCR.
  - Requires macOS Vision and ImageMagick (`magick`).
EOF
      exit 0
      ;;
    *)
      if [ -n "$INPUT" ]; then
        echo "Only one input path is supported." >&2
        exit 1
      fi
      INPUT="$1"
      shift
      ;;
  esac
done

if [ -z "$INPUT" ]; then
  echo "Missing input path. Try: tools/ocr-vision --help" >&2
  exit 1
fi

if [ ! -f "$INPUT" ]; then
  echo "Input not found: $INPUT" >&2
  exit 1
fi

case "${INPUT##*.}" in
  pdf|PDF)
    if ! command -v magick >/dev/null 2>&1; then
      echo "magick is required for PDF rendering." >&2
      exit 1
    fi
    TMP_DIR="$(mktemp -d)"
    trap 'rm -rf "$TMP_DIR"' EXIT INT TERM
    PAGE_INDEX=$((PAGE - 1))
    RENDERED="$TMP_DIR/page.png"
    magick -density "$DENSITY" "$INPUT[$PAGE_INDEX]" -alpha off -colorspace Gray "$RENDERED"
    exec swift "$SWIFT_SCRIPT" "$RENDERED"
    ;;
  *)
    exec swift "$SWIFT_SCRIPT" "$INPUT"
    ;;
esac
